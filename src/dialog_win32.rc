#include <windows.h>
#include "resource.h"

IDD_SEPARATE DIALOGEX 0, 0, 300, 68
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Separate Stems"
FONT 8, "MS Shell Dlg"
BEGIN
